{
  "name": "quantproof",
  "version": "0.1.1",
  "description": "Runs your real task examples against local quantized models via Ollama and recommends the smallest quant that holds quality.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonrunnerkc/quantproof.git"
  },
  "homepage": "https://github.com/moonrunnerkc/quantproof#readme",
  "bugs": "https://github.com/moonrunnerkc/quantproof/issues",
  "keywords": [
    "llm",
    "evaluation",
    "quantization",
    "ollama",
    "local-llm",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "quantproof": "dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"fs.chmodSync('dist/cli/main.js', 0o755)\"",
    "prepack": "tsc -p tsconfig.build.json && node -e \"fs.chmodSync('dist/cli/main.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.1",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-import-x": "^4.17.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
