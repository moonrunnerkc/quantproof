{
  "name": "quantproof",
  "version": "0.1.0",
  "description": "Runs your real task examples against local quantized models via Ollama and recommends the smallest quant that holds quality.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "quantproof": "dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "echo 'e2e smoke test lands in phase 1; it needs a live Ollama instance. Run: npm test' && exit 0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-import-x": "^4.17.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
